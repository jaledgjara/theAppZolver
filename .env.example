# =============================================================================
# Zolver — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.
# =============================================================================

# ─── Firebase (Client-side, bundled into app) ─────────────────────────────────
EXPO_PUBLIC_FIREBASE_WEB_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=

# ─── Google Sign-In (per-platform OAuth client IDs) ──────────────────────────
EXPO_PUBLIC_FIREBASE_IOS_CLIENT=
EXPO_PUBLIC_FIREBASE_ANDROID_CLIENT=
EXPO_PUBLIC_FIREBASE_WEB_CLIENT=

# ─── Supabase (Client-side) ──────────────────────────────────────────────────
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
EXPO_PUBLIC_SUPABASE_URL_FUNCTIONS=

# ─── Mercado Pago (Client-side public key) ───────────────────────────────────
EXPO_PUBLIC_MP_PUBLIC_KEY=

# ─── Sentry (Crash Reporting) ────────────────────────────────────────────────
EXPO_PUBLIC_SENTRY_DSN=

# ─── Auth Redirects ──────────────────────────────────────────────────────────
EXPO_PUBLIC_EMAIL_LINK_REDIRECT_URL=https://thezolverapp.web.app/auth/email-link
EXPO_PUBLIC_IOS_BUNDLE_ID=com.the.zolver.app
EXPO_PUBLIC_ANDROID_PACKAGE=com.the.zolver.app
